<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Documentary and portrait photographer based in Venice. Weddings, music, street photography and travel stories.">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&Bona+Nova:ital,wght@0,400;0,700;1,400&family=Libre+Baskerville:ital,wght@0,400..700;1,400..700family=Source+Sans+3:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">

<meta property="og:title" content="Biemmezeta – Photographer">
<meta property="og:description" content="Portrait, documentary and travel photography from Venice.">
<meta property="og:type" content="website">

<script type="application/ld+json">
{
 "@context": "https://schema.org",
 "@type": "Person",
 "name": "Brunetto Marco Ziosi",
 "jobTitle": "Photographer",
 "url": "https://biemmezeta.com",
 "sameAs": [
   "https://www.instagram.com/biemmezeta"
 ]
}
</script>

<link rel="stylesheet" href="/css/style.css?{{ build.time }}">
<link rel="stylesheet" href="/js/photoswipe/photoswipe.css">

<script>
window.heroImages = [
{% for img in heroImages %}
  "{{ img | url }}",
{% endfor %}
];
</script>

<script src="/js/navigation.js" defer></script>
<script type="module" src="/js/gallery.js" defer></script>
</head>

<body>
<div id="top"></div>
<header class="hero" id="hero">
<h1>biemmezeta</h1>
<div class="scroll-hint" id="scroll-hint">
    ↓
</div>
</header>

<main>
{{ content | safe }}
</main>

</body>
</html>