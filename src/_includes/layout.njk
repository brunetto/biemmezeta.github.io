<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta
            name="description"
            content="Documentary and portrait photographer based in Venice. Weddings, music, street photography and travel stories.">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="crossorigin">
        <link
            href="https://fonts.googleapis.com/css2?family=Bona+Nova:wght@400;700&family=Source+Sans+3:wght@300;400;600&display=swap"
            rel="stylesheet">
        <meta property="og:title" content="Biemmezeta – Photographer">
        <meta property="og:description" content="Portrait, documentary and travel photography from Venice.">
        <meta property="og:type" content="website">
        <script type="application/ld+json">
            { "@context": "https://schema.org", "@type": "Person", "name": "Brunetto Marco Ziosi", "jobTitle": "Photographer",
            "url": "https://biemmezeta.com", "sameAs": ["https://www.instagram.com/biemmezeta"] }
        </script>
        <base href="{{ '/' | url }}">
        <link rel="stylesheet" href="{{ basePath }}css/style.css?{{ build.time }}">
        <link rel="stylesheet" href="{{ basePath }}js/photoswipe/photoswipe.css">
        <script src="{{ basePath }}js/navigation.js" defer="defer"></script>
        <script type="module" src="{{ basePath }}js/gallery.js" defer="defer"></script>
        <link rel="icon" href="{{ basePath }}favicon.ico">
    </head>
    <body>
        <main>
            {{ content | safe }}
        </main>
        {% if pageScripts %}
            {{ pageScripts | safe }}
        {% endif %}
    </body>
</html>